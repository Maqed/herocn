  "files": [
    {
      "path": "components/examples/input-group-icon.tsx",
      "content": "import {\n\tCheckIcon,\n\tCreditCardIcon,\n\tInfoIcon,\n\tMailIcon,\n\tSearchIcon,\n\tStarIcon,\n} from \"lucide-react\";\n\nimport {\n\tInputGroup,\n\tInputGroupAddon,\n\tInputGroupInput,\n} from \"@/components/ui/input-group\";\n\nexport default function InputGroupIcon() {\n\treturn (\n\t\t<div className=\"grid w-full max-w-sm gap-6\">\n\t\t\t<InputGroup>\n\t\t\t\t<InputGroupInput placeholder=\"Search...\" />\n\t\t\t\t<InputGroupAddon>\n\t\t\t\t\t<SearchIcon />\n\t\t\t\t</InputGroupAddon>\n\t\t\t</InputGroup>\n\t\t\t<InputGroup>\n\t\t\t\t<InputGroupInput type=\"email\" placeholder=\"Enter your email\" />\n\t\t\t\t<InputGroupAddon>\n\t\t\t\t\t<MailIcon />\n\t\t\t\t</InputGroupAddon>\n\t\t\t</InputGroup>\n\t\t\t<InputGroup>\n\t\t\t\t<InputGroupInput placeholder=\"Card number\" />\n\t\t\t\t<InputGroupAddon>\n\t\t\t\t\t<CreditCardIcon />\n\t\t\t\t</InputGroupAddon>\n\t\t\t\t<InputGroupAddon align=\"inline-end\">\n\t\t\t\t\t<CheckIcon />\n\t\t\t\t</InputGroupAddon>\n\t\t\t</InputGroup>\n\t\t\t<InputGroup>\n\t\t\t\t<InputGroupInput placeholder=\"Card number\" />\n\t\t\t\t<InputGroupAddon align=\"inline-end\">\n\t\t\t\t\t<StarIcon />\n\t\t\t\t\t<InfoIcon />\n\t\t\t\t</InputGroupAddon>\n\t\t\t</InputGroup>\n\t\t</div>\n\t);\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}