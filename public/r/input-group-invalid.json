      "path": "components/examples/input-group-invalid.tsx",
      "content": "import { SearchIcon } from \"lucide-react\";\n\nimport { Field, FieldError, FieldLabel } from \"@/components/ui/field\";\nimport {\n\tInputGroup,\n\tInputGroupAddon,\n\tInputGroupInput,\n\tInputGroupTextarea,\n} from \"@/components/ui/input-group\";\n\nexport default function InputGroupInvalid() {\n\treturn (\n\t\t<div className=\"grid w-full max-w-sm gap-6\">\n\t\t\t<Field data-invalid>\n\t\t\t\t<FieldLabel htmlFor=\"invalid-input\">Search</FieldLabel>\n\t\t\t\t<InputGroup>\n\t\t\t\t\t<InputGroupInput\n\t\t\t\t\t\tid=\"invalid-input\"\n\t\t\t\t\t\taria-invalid\n\t\t\t\t\t\tplaceholder=\"Search...\"\n\t\t\t\t\t/>\n\t\t\t\t\t<InputGroupAddon>\n\t\t\t\t\t\t<SearchIcon />\n\t\t\t\t\t</InputGroupAddon>\n\t\t\t\t</InputGroup>\n\t\t\t\t<FieldError>Please enter a valid search term.</FieldError>\n\t\t\t</Field>\n\t\t\t<Field data-invalid>\n\t\t\t\t<FieldLabel htmlFor=\"invalid-textarea\">Message</FieldLabel>\n\t\t\t\t<InputGroup>\n\t\t\t\t\t<InputGroupTextarea\n\t\t\t\t\t\tid=\"invalid-textarea\"\n\t\t\t\t\t\taria-invalid\n\t\t\t\t\t\tplaceholder=\"Enter your message...\"\n\t\t\t\t\t/>\n\t\t\t\t</InputGroup>\n\t\t\t\t<FieldError>Message cannot be empty.</FieldError>\n\t\t\t</Field>\n\t\t</div>\n\t);\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}