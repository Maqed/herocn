{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "dialog-close-button",
  "registryDependencies": [
    "https://herocn.dev/r/button.json",
    "https://herocn.dev/r/dialog.json",
    "https://herocn.dev/r/input.json",
    "https://herocn.dev/r/label.json"
  ],
  "files": [
    {
      "path": "components/examples/dialog-close-button.tsx",
      "content": "\"use client\";\n\nimport { Button } from \"@/components/ui/button\";\nimport {\n\tDialog,\n\tDialogClose,\n\tDialogContent,\n\tDialogDescription,\n\tDialogFooter,\n\tDialogHeader,\n\tDialogTitle,\n\tDialogTrigger,\n} from \"@/components/ui/dialog\";\nimport { Input } from \"@/components/ui/input\";\nimport { Label } from \"@/components/ui/label\";\n\nexport default function DialogCloseButton() {\n\treturn (\n\t\t<Dialog>\n\t\t\t<DialogTrigger render={<Button variant=\"tertiary\" />}>\n\t\t\t\tShare\n\t\t\t</DialogTrigger>\n\t\t\t<DialogContent className=\"sm:max-w-md\">\n\t\t\t\t<DialogHeader>\n\t\t\t\t\t<DialogTitle>Share link</DialogTitle>\n\t\t\t\t\t<DialogDescription>\n\t\t\t\t\t\tAnyone who has this link will be able to view this.\n\t\t\t\t\t</DialogDescription>\n\t\t\t\t</DialogHeader>\n\t\t\t\t<div className=\"flex items-center gap-2\">\n\t\t\t\t\t<div className=\"grid flex-1 gap-2\">\n\t\t\t\t\t\t<Label htmlFor=\"link\" className=\"sr-only\">\n\t\t\t\t\t\t\tLink\n\t\t\t\t\t\t</Label>\n\t\t\t\t\t\t<Input\n\t\t\t\t\t\t\tvariant=\"secondary\"\n\t\t\t\t\t\t\tid=\"link\"\n\t\t\t\t\t\t\tdefaultValue=\"https://herocn.dev/docs/installation\"\n\t\t\t\t\t\t\treadOnly\n\t\t\t\t\t\t/>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t\t<DialogFooter className=\"sm:justify-start\">\n\t\t\t\t\t<DialogClose render={<Button type=\"button\" />}>Close</DialogClose>\n\t\t\t\t</DialogFooter>\n\t\t\t</DialogContent>\n\t\t</Dialog>\n\t);\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}