      "path": "components/examples/avatar-demo.tsx",
      "content": "import {\n\tAvatar,\n\tAvatarBadge,\n\tAvatarFallback,\n\tAvatarGroup,\n\tAvatarGroupCount,\n\tAvatarImage,\n} from \"@/components/ui/avatar\";\n\nexport default function AvatarDemo() {\n\treturn (\n\t\t<div className=\"flex flex-row flex-wrap items-center justify-center gap-6 md:gap-12\">\n\t\t\t<Avatar>\n\t\t\t\t<AvatarImage src=\"https://github.com/Maqed.png\" alt=\"@0xMaqed\" />\n\t\t\t\t<AvatarFallback>Mqd</AvatarFallback>\n\t\t\t</Avatar>\n\t\t\t<Avatar>\n\t\t\t\t<AvatarImage\n\t\t\t\t\tsrc=\"https://github.com/evilrabbit.png\"\n\t\t\t\t\talt=\"@evilrabbit\"\n\t\t\t\t/>\n\t\t\t\t<AvatarFallback>ER</AvatarFallback>\n\t\t\t\t<AvatarBadge className=\"bg-green-600 dark:bg-green-800\" />\n\t\t\t</Avatar>\n\t\t\t<AvatarGroup>\n\t\t\t\t<Avatar>\n\t\t\t\t\t<AvatarImage src=\"https://github.com/shadcn.png\" alt=\"@shadcn\" />\n\t\t\t\t\t<AvatarFallback>CN</AvatarFallback>\n\t\t\t\t</Avatar>\n\t\t\t\t<Avatar>\n\t\t\t\t\t<AvatarImage\n\t\t\t\t\t\tsrc=\"https://github.com/maxleiter.png\"\n\t\t\t\t\t\talt=\"@maxleiter\"\n\t\t\t\t\t/>\n\t\t\t\t\t<AvatarFallback>LR</AvatarFallback>\n\t\t\t\t</Avatar>\n\t\t\t\t<Avatar>\n\t\t\t\t\t<AvatarImage\n\t\t\t\t\t\tsrc=\"https://github.com/evilrabbit.png\"\n\t\t\t\t\t\talt=\"@evilrabbit\"\n\t\t\t\t\t/>\n\t\t\t\t\t<AvatarFallback>ER</AvatarFallback>\n\t\t\t\t</Avatar>\n\t\t\t\t<AvatarGroupCount>+3</AvatarGroupCount>\n\t\t\t</AvatarGroup>\n\t\t</div>\n\t);\n}\n",
      "type": "registry:example"
    }
