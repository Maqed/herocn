{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tabs-icons",
  "registryDependencies": [
    "https://herocn.dev/r/tabs.json"
  ],
  "files": [
    {
      "path": "components/examples/tabs-icons.tsx",
      "content": "import { AppWindowIcon, CodeIcon } from \"lucide-react\";\n\nimport {\n  Tabs,\n  TabsContent,\n  TabsList,\n  TabsTrigger,\n} from \"@/components/ui/tabs\";\n\nexport function TabsIcons() {\n  return (\n    <Tabs defaultValue=\"preview\" className=\"w-[400px]\">\n      <TabsList>\n        <TabsTrigger value=\"preview\">\n          <AppWindowIcon />\n          Preview\n        </TabsTrigger>\n        <TabsTrigger value=\"code\">\n          <CodeIcon />\n          Code\n        </TabsTrigger>\n      </TabsList>\n      <TabsContent value=\"preview\">\n        <p className=\"text-sm text-muted-foreground\">\n          See a live preview of your component as it will appear in the browser.\n        </p>\n      </TabsContent>\n      <TabsContent value=\"code\">\n        <p className=\"text-sm text-muted-foreground\">\n          View and copy the source code for this component to use in your\n          project.\n        </p>\n      </TabsContent>\n    </Tabs>\n  );\n}\n",
      "type": "registry:example"
    }
  ],
  "type": "registry:example"
}